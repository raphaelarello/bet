# Rapha Guru — Variáveis de Ambiente
# Copie para .env e preencha os valores

# ── JWT ──────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_DE_64_CHARS

# ── Pagar.me ─────────────────────────────────────────────────
# Crie conta em https://pagar.me (grátis para testar)
# Copie a chave de API do dashboard → Configurações → Chaves de API
PAGARME_API_KEY=ak_test_SUA_CHAVE_AQUI

# Webhook secret (configure no painel Pagar.me → Webhooks)
PAGARME_WEBHOOK_SECRET=SUA_WEBHOOK_SECRET

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Banco de dados ────────────────────────────────────────────
# O banco SQLite é criado automaticamente em data/rapha.db
# Não precisa configurar nada

# ── Admin padrão ──────────────────────────────────────────────
# Criado automaticamente no primeiro start:
# Email: admin@raphaguru.com
# Senha: Admin@2024
# TROQUE A SENHA após o primeiro login em /minha-conta
